PORT=8080
NODE_ENV=production

# PostgreSQL 연결 URL (AWS RDS 사용 시 해당 엔드포인트로 교체)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ingang?schema=public"

# JWT 서명 키 (충분히 긴 랜덤 문자열로 교체)
JWT_SECRET="change-me-to-a-long-random-string"

# 허용할 프론트엔드 출처 (쉼표로 구분해 여러 개 가능)
ALLOWED_ORIGINS="https://your-frontend-domain.com"

# 토스 페이먼츠 시크릿 키
TOSS_SECRET_KEY="your-toss-secret-key"
